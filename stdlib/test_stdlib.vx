// test_stdlib.vx — Smoke test for the Vulpes standard library
// Exercises math, string, collections, and io modules

from math import { sqrt, sin, cos, abs, floor, ceil, round, min, max, clamp, sign,
                    is_even, is_odd, pow, gcd, lcm, factorial, fib,
                    deg_to_rad, rad_to_deg, tan, log10, log2, hypot, lerp,
                    PI, E };
from string import { to_string, to_int, to_float, substr, find, split, contains,
                      starts_with, ends_with, repeat, join, replace,
                      char_code, from_char_code, is_digit, is_alpha, is_upper, is_lower,
                      to_upper, to_lower, trim, reverse_string, chars, pad_left, pad_right };
from collections import { range, range_from, range_step, map_vec, filter, reduce,
                           for_each, sum, product, any, all, contains_val, index_of,
                           count, reverse, zip, enumerate, flat_map, take, drop,
                           sort, min_val, max_val };
from io import { read_file, write_file };

// ── Test infrastructure ──

let tests_passed = 0;
let tests_failed = 0;

fn assert_eq(actual, expected, label) {
    if actual == expected {
        tests_passed = tests_passed + 1;
    } else {
        tests_failed = tests_failed + 1;
        println("FAIL: " + label);
        println("  expected: " + to_string(expected));
        println("  actual:   " + to_string(actual));
    }
}

fn assert_true(val, label) {
    assert_eq(val, true, label);
}

fn assert_false(val, label) {
    assert_eq(val, false, label);
}

// ── Math tests ──

assert_eq(floor(sqrt(4.0)), 2, "sqrt(4)");
assert_eq(floor(sqrt(9.0)), 3, "sqrt(9)");

assert_eq(abs(-5), 5, "abs(-5)");
assert_eq(abs(3), 3, "abs(3)");

assert_eq(floor(3.7), 3, "floor(3.7)");
assert_eq(ceil(3.2), 4, "ceil(3.2)");
assert_eq(round(3.5), 4, "round(3.5)");
assert_eq(round(3.4), 3, "round(3.4)");

assert_eq(min(3, 7), 3, "min(3,7)");
assert_eq(max(3, 7), 7, "max(3,7)");
assert_eq(clamp(5, 0, 10), 5, "clamp(5,0,10)");
assert_eq(clamp(-1, 0, 10), 0, "clamp(-1,0,10)");
assert_eq(clamp(15, 0, 10), 10, "clamp(15,0,10)");

assert_eq(sign(5), 1, "sign(5)");
assert_eq(sign(-3), -1, "sign(-3)");
assert_eq(sign(0), 0, "sign(0)");

assert_true(is_even(4), "is_even(4)");
assert_false(is_even(3), "is_even(3)");
assert_true(is_odd(7), "is_odd(7)");
assert_false(is_odd(8), "is_odd(8)");

assert_eq(pow(2, 10), 1024, "pow(2,10)");
assert_eq(gcd(12, 8), 4, "gcd(12,8)");
assert_eq(gcd(7, 5), 1, "gcd(7,5)");
assert_eq(lcm(4, 6), 12, "lcm(4,6)");

assert_eq(factorial(0), 1, "factorial(0)");
assert_eq(factorial(1), 1, "factorial(1)");
assert_eq(factorial(5), 120, "factorial(5)");

assert_eq(fib(0), 0, "fib(0)");
assert_eq(fib(1), 1, "fib(1)");
assert_eq(fib(10), 55, "fib(10)");

assert_eq(floor(hypot(3, 4)), 5, "hypot(3,4)");
assert_eq(lerp(0, 10, 0.5), 5.0, "lerp(0,10,0.5)");

assert_eq(floor(log10(100.0)), 2, "log10(100)");
assert_eq(floor(log2(8.0)), 3, "log2(8)");

// sin(0) == 0, cos(0) == 1
assert_eq(floor(sin(0.0) * 1000), 0, "sin(0)");
assert_eq(floor(cos(0.0) * 1000), 1000, "cos(0)");

// ── String tests ──

assert_eq(to_string(42), "42", "to_string(42)");
assert_eq(to_int("123"), 123, "to_int(123)");
assert_eq(floor(to_float("3.14")), 3, "to_float(3.14)");

assert_eq(substr("hello world", 0, 5), "hello", "substr");
assert_eq(find("hello", "ll"), 2, "find");
assert_eq(find("hello", "xyz"), -1, "find missing");

assert_true(contains("hello world", "world"), "contains true");
assert_false(contains("hello world", "xyz"), "contains false");

assert_true(starts_with("hello", "hel"), "starts_with true");
assert_false(starts_with("hello", "xyz"), "starts_with false");

assert_true(ends_with("hello", "llo"), "ends_with true");
assert_false(ends_with("hello", "xyz"), "ends_with false");

assert_eq(repeat("ab", 3), "ababab", "repeat");
assert_eq(repeat("x", 0), "", "repeat 0");

let parts = split("a,b,c", ",");
assert_eq(len(parts), 3, "split len");
assert_eq(parts[0], "a", "split[0]");
assert_eq(parts[2], "c", "split[2]");

assert_eq(join(vec("a", "b", "c"), "-"), "a-b-c", "join");
assert_eq(replace("hello world", "world", "vulpes"), "hello vulpes", "replace");

assert_eq(char_code("A"), 65, "char_code A");
assert_eq(from_char_code(65), "A", "from_char_code 65");

assert_true(is_digit("5"), "is_digit 5");
assert_false(is_digit("a"), "is_digit a");
assert_true(is_alpha("z"), "is_alpha z");
assert_false(is_alpha("1"), "is_alpha 1");
assert_true(is_upper("Z"), "is_upper Z");
assert_false(is_upper("z"), "is_upper z");
assert_true(is_lower("a"), "is_lower a");
assert_false(is_lower("A"), "is_lower A");

assert_eq(to_upper("hello"), "HELLO", "to_upper");
assert_eq(to_lower("WORLD"), "world", "to_lower");
assert_eq(trim("  hello  "), "hello", "trim");
assert_eq(reverse_string("abc"), "cba", "reverse_string");

let ch = chars("hey");
assert_eq(len(ch), 3, "chars len");
assert_eq(ch[0], "h", "chars[0]");

assert_eq(pad_left("42", 5, "0"), "00042", "pad_left");
assert_eq(pad_right("hi", 5, "."), "hi...", "pad_right");

// ── Collections tests ──

let r = range(5);
assert_eq(len(r), 5, "range len");
assert_eq(r[0], 0, "range[0]");
assert_eq(r[4], 4, "range[4]");

let r2 = range_from(3, 7);
assert_eq(len(r2), 4, "range_from len");
assert_eq(r2[0], 3, "range_from[0]");
assert_eq(r2[3], 6, "range_from[3]");

let r3 = range_step(0, 10, 3);
assert_eq(len(r3), 4, "range_step len");
assert_eq(r3[0], 0, "range_step[0]");
assert_eq(r3[3], 9, "range_step[3]");

let doubled = map_vec(vec(1, 2, 3), fn(x) { return x * 2; });
assert_eq(len(doubled), 3, "map len");
assert_eq(doubled[0], 2, "map[0]");
assert_eq(doubled[2], 6, "map[2]");

let evens = filter(vec(1, 2, 3, 4, 5), fn(x) { return x % 2 == 0; });
assert_eq(len(evens), 2, "filter len");
assert_eq(evens[0], 2, "filter[0]");
assert_eq(evens[1], 4, "filter[1]");

let total = reduce(vec(1, 2, 3, 4), 0, fn(a, b) { return a + b; });
assert_eq(total, 10, "reduce sum");

assert_eq(sum(vec(1, 2, 3, 4, 5)), 15, "sum");
assert_eq(product(vec(1, 2, 3, 4)), 24, "product");

assert_true(any(vec(1, 2, 3), fn(x) { return x > 2; }), "any true");
assert_false(any(vec(1, 2, 3), fn(x) { return x > 5; }), "any false");
assert_true(all(vec(1, 2, 3), fn(x) { return x > 0; }), "all true");
assert_false(all(vec(1, 2, 3), fn(x) { return x > 1; }), "all false");

assert_true(contains_val(vec(1, 2, 3), 2), "contains_val true");
assert_false(contains_val(vec(1, 2, 3), 5), "contains_val false");

assert_eq(index_of(vec(10, 20, 30), 20), 1, "index_of found");
assert_eq(index_of(vec(10, 20, 30), 99), -1, "index_of missing");

assert_eq(count(vec(1, 2, 3, 4, 5), fn(x) { return x > 3; }), 2, "count");

let rev = reverse(vec(1, 2, 3));
assert_eq(rev[0], 3, "reverse[0]");
assert_eq(rev[2], 1, "reverse[2]");

let zipped = zip(vec("a", "b"), vec(1, 2));
assert_eq(len(zipped), 2, "zip len");
assert_eq(zipped[0][0], "a", "zip[0][0]");
assert_eq(zipped[0][1], 1, "zip[0][1]");

let en = enumerate(vec("x", "y", "z"));
assert_eq(en[0][0], 0, "enumerate[0][0]");
assert_eq(en[0][1], "x", "enumerate[0][1]");
assert_eq(en[2][0], 2, "enumerate[2][0]");

let flat = flat_map(vec(1, 2, 3), fn(x) { return vec(x, x * 10); });
assert_eq(len(flat), 6, "flat_map len");
assert_eq(flat[0], 1, "flat_map[0]");
assert_eq(flat[1], 10, "flat_map[1]");

assert_eq(len(take(vec(1, 2, 3, 4, 5), 3)), 3, "take len");
assert_eq(take(vec(1, 2, 3, 4, 5), 3)[2], 3, "take[2]");

let d = drop(vec(1, 2, 3, 4, 5), 2);
assert_eq(len(d), 3, "drop len");
assert_eq(d[0], 3, "drop[0]");

let sorted = sort(vec(5, 3, 1, 4, 2));
assert_eq(sorted[0], 1, "sort[0]");
assert_eq(sorted[4], 5, "sort[4]");

assert_eq(min_val(vec(3, 1, 4, 1, 5)), 1, "min_val");
assert_eq(max_val(vec(3, 1, 4, 1, 5)), 5, "max_val");

// ── I/O tests ──

write_file("/tmp/vulpes_test_io.txt", "hello from vulpes");
let content = read_file("/tmp/vulpes_test_io.txt");
assert_eq(content, "hello from vulpes", "write/read file");

// ── Integration: combining modules ──

// Use math + collections together
let squares = map_vec(range_from(1, 6), fn(x) { return x ** 2; });
assert_eq(squares[0], 1, "squares[0]");
assert_eq(squares[4], 25, "squares[4]");
assert_eq(sum(squares), 55, "sum of squares");

// Use string + collections together
let words = split("the quick brown fox", " ");
let upper_words = map_vec(words, fn(w) { return to_upper(w); });
assert_eq(join(upper_words, " "), "THE QUICK BROWN FOX", "upper sentence");

// Functional pipeline
let result = reduce(
    filter(
        map_vec(range(10), fn(x) { return x * x; }),
        fn(x) { return x % 2 == 0; }
    ),
    0,
    fn(a, b) { return a + b; }
);
assert_eq(result, 120, "functional pipeline");

// ── Print results ──

println("");
println("=== Vulpes stdlib smoke test ===");
println(to_string(tests_passed) + " passed, " + to_string(tests_failed) + " failed");

if tests_failed > 0 {
    throw_err("Some tests failed!");
}

println("All tests passed!");
